# Application
APP_NAME=Visitor Management System
DEBUG=true
ENVIRONMENT=development

# Database – Supabase only. Get the URI from: Supabase Dashboard → Project Settings → Database → Connection string.
# Direct (port 5432):
#   DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Session pooler (port 6543; use if direct fails or times out). You can paste postgres://... as-is:
#   DATABASE_URL=postgres://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql+asyncpg://postgres:UZBuN4EPMSNAViLh@db.PROJECT_REF.supabase.co:5432/postgres
# Database – Supabase (use postgresql+asyncpg for async). Replace [YOUR-PASSWORD] with your DB password.
DATABASE_URL=postgresql+asyncpg://postgres:UZBuN4EPMSNAViLh@db.ibuskfesyzvyruhudvvr.supabase.co:5432/postgres
# DB_USE_SSL=false   # Set true only if Supabase requires SSL (e.g. pooler); default is no SSL

